DJANGO_SECRET_KEY=change-me-to-a-random-secret
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Used to build DATABASE_URL below, and by docker-compose to configure the
# db service's own POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB.
POSTGRES_USER=marketing
POSTGRES_PASSWORD=marketing
POSTGRES_DB=marketing_analytics

# For local (non-Docker) dev, this points at localhost. docker-compose
# overrides this at runtime to point the web service at the db service
# instead - see docker-compose.yml.
DATABASE_URL=postgres://marketing:marketing@localhost:5432/marketing_analytics

# Get a key at https://console.anthropic.com/ - the ask-your-data feature
# fails gracefully (a 502 with a clear message) if this is left blank.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
